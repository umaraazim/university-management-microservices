# API Gateway Configuration
PORT=3000

# Service URLs
STUDENT_SERVICE_URL=http://localhost:3001
COURSE_SERVICE_URL=http://localhost:3002
LECTURER_SERVICE_URL=http://localhost:3003
RESULT_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_URL=http://localhost:3005

# Proxy timeout (milliseconds)
PROXY_TIMEOUT=30000

# CORS origin (use * for development, specific domain for production)
CORS_ORIGIN=*

# Environment
NODE_ENV=development
